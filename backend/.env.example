# ─────────────────────────────────────────────
#  Carbon Footprint System — Environment Config
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Local example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/carbon_footprint_db?schema=public"
#
# Aiven PostgreSQL example:
# Copy the Service URI from Aiven, then append schema=public.
# Keep sslmode=require because Aiven requires SSL.
DATABASE_URL="postgresql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?sslmode=require&schema=public"

# NestJS
PORT=3000
NODE_ENV=development

# JWT (for future auth)
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d
